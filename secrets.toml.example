# Example secrets file — copy to .streamlit/secrets.toml and fill in values
# DO NOT commit secrets.toml to git (it's in .gitignore)

[auth]
# Set this to your deployed Streamlit URL + "/oauth2callback"
# Example: "https://exodus-underwriting.streamlit.app/oauth2callback"
redirect_uri = "https://YOUR-APP-URL.streamlit.app/oauth2callback"

# Generate a long random string with: python -c "import secrets; print(secrets.token_hex(32))"
cookie_secret = "REPLACE_WITH_LONG_RANDOM_STRING"

# Google OAuth credentials — get these from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
client_id = "YOUR_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_CLIENT_SECRET"

# Use Google's standard OIDC config
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# Allow-listed team emails
[allowed_emails]
emails = [
    "jo@exoduspropertysolutions.com",
    # add your teammates here
]
